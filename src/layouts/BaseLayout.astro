---
// src/layouts/BaseLayout.astro
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Pranay — Founder & Writer", 
  description = "Personal website, story, and writing of Pranay." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-F9VFZKD07P"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-F9VFZKD07P');
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  
  <!-- SEO Best Practices -->
  <link rel="canonical" href="https://pranaym.com" />
  <meta name="robots" content="index, follow" />
  
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content="https://pranaym.com" />
  <meta property="og:image" content="https://pranaym.com/images/portrait.png" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:site" content="@pranaym0" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" />

  <!-- GEO/AEO Entity Linked Graph (Schema.org) -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "@id": "https://pranaym.com/#person",
          "name": "Pranay",
          "url": "https://pranaym.com",
          "sameAs": [
            "https://www.linkedin.com/in/pranaym/",
            "https://twitter.com/pranaym0",
            "https://instagram.com/xerk"
          ],
          "jobTitle": "Tech Founder & Writer",
          "knowsAbout": [
            "Software Engineering",
            "Startup Architecture",
            "Generative AI",
            "Product Leadership"
          ],
          "description": "A tech founder, engineer, and writer based in São Paulo, Brazil."
        },
        {
          "@type": "WebSite",
          "@id": "https://pranaym.com/#website",
          "url": "https://pranaym.com",
          "name": "Pranay Mehrotra",
          "description": "Personal website, story, and essays of Pranay.",
          "publisher": {
            "@id": "https://pranaym.com/#person"
          }
        }
      ]
    }
  </script>

  <!-- Color Mode Script (Anti-FOUC) -->
  <script is:inline>
    (function() {
      function setColorMode(isLight, savePreference = true) {
        document.documentElement.classList.toggle('light-mode', isLight);
        const checkbox = document.getElementById('color-mode');
        if (checkbox) {
          checkbox.checked = isLight;
        }
        if (savePreference) {
          localStorage.setItem('theme', isLight ? 'light' : 'dark');
        }
      }

      const savedTheme = localStorage.getItem('theme');
      let prefersLight;
      let usingOSPreference = false;

      if (savedTheme !== null) {
        prefersLight = savedTheme === 'light';
      } else {
        const prefersColorScheme = window.matchMedia('(prefers-color-scheme: light)');
        prefersLight = prefersColorScheme.matches;
        usingOSPreference = true;
      }

      setColorMode(prefersLight, !usingOSPreference);

      function initToggle() {
        const checkbox = document.getElementById('color-mode');
        if (checkbox) {
          checkbox.checked = document.documentElement.classList.contains('light-mode');
          checkbox.addEventListener('change', function() {
            usingOSPreference = false;
            setColorMode(this.checked);
          });
          const toggleLabel = document.querySelector('.toggle-label');
          if (toggleLabel) {
            setTimeout(function() {
              toggleLabel.classList.add('has-transition');
            }, 100);
          }
        }
      }

      if (document.readyState === 'loading') {
        window.addEventListener('DOMContentLoaded', initToggle);
      } else {
        initToggle();
      }

      document.addEventListener('astro:after-swap', initToggle);

      const prefersColorScheme = window.matchMedia('(prefers-color-scheme: light)');
      prefersColorScheme.addEventListener('change', (e) => {
        if (usingOSPreference) {
          setColorMode(e.matches, false);
        }
      });
    })();
  </script>
</head>
<body>
  <div class="container">
    <!-- Global Minimal Header -->
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="logo">Pranay Mehrotra</a>
        <nav>
          <ul class="nav-links">
            <li><a href="/about">About</a></li>
            <li><a href="/blog">Blog</a></li>
            <li>
              <div class="toggle-switch" title="Toggle dark/light mode">
                <input type="checkbox" id="color-mode" name="Color Mode" class="toggle-checkbox" aria-label="Toggle dark/light mode">
                <label for="color-mode" class="toggle-label"></label>
              </div>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- Dynamic Slot for Page Contents -->
    <main>
      <slot />
    </main>

    <!-- Global Footer -->
    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-copy">&copy; {new Date().getFullYear()} Pranay. Built with Astro.</p>
        <div>
          <a href="/llms.txt" class="ai-bot-link" target="_blank">
            <span>🤖 llms.txt — Optimized for AI Crawlers</span>
          </a>
        </div>
      </div>
    </footer>
  </div>
</body>
</html>
