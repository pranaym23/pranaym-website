---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

const posts = await getCollection('blog');
// Sort posts by publication date in descending order (newest first)
const sortedPosts = posts.sort((a, b) => {
  return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
});

// Dynamic reading of optimized WebP images in the production folder
const imagesDir = path.resolve('./public/images');
let webpImages = [];
try {
  if (fs.existsSync(imagesDir)) {
    webpImages = fs.readdirSync(imagesDir)
      .filter(file => file.endsWith('.webp') && !file.startsWith('.'))
      .sort() // Keeps them in their sorted order (photo-001, photo-002, etc.)
      .map(file => `/images/${file}`);
  }
} catch (error) {
  console.error('Error reading optimized images directory:', error);
}
---

<BaseLayout>
  <!-- Short Profile Section -->
  <section class="profile-intro">
    <div class="profile-grid">
      <div class="profile-image-container">
        <img src="/images/portrait.png" alt="Pranay Mehrotra" class="profile-avatar" />
      </div>
      <div class="profile-text">
        <p class="lead">
          I am Pranay. A tech founder, product-guy, working with Applied AI based in São Paulo, Brazil. I also consider myself to be a bit of a writer and a wannabe musician.
        </p>
        <p>
          I build digital products, try to design resilient architectures, and reflect on the journey. I believe that building a company is as much an act of self-discovery as it is an exercise in actually building it, and that true growth only happens on the edge of comfort. This site has a lot of old stuff, is a reasonably accurate representation of who I am and I hope I don't regret putting it all online.
        </p>
      </div>
    </div>
  </section>



  <!-- Text-based Social Links (Excluding Medium) -->
  <ul class="social-links">
    <li>
      <a href="https://www.linkedin.com/in/pranaym/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    </li>
    <li>
      <a href="https://twitter.com/pranaym0" target="_blank" rel="noopener noreferrer">Twitter / X</a>
    </li>
    <li>
      <a href="https://instagram.com/xerk" target="_blank" rel="noopener noreferrer">Instagram</a>
    </li>
    <li>
      <a href="https://open.spotify.com/artist/1SwRcpUgmqdoprGlXhphF2" target="_blank" rel="noopener noreferrer">Spotify</a>
    </li>
  </ul>

  <!-- Photography Reel Section (Dynamic WebP loading with SEO Alt Tags) -->
  {webpImages.length > 0 && (
    <section class="photography-section">
      <h2 class="photography-title">
        My Travel Photography <span class="title-action-hint">[Hover to reveal]</span>
      </h2>
      <div class="photo-reel">
        {webpImages.map((imagePath) => {
          const baseName = path.basename(imagePath, '.webp');
          
          // Parse the location slug out of the filename
          // e.g., pranay-m-travel-photography-edinburgh-scotland-uk-01 -> locationPart = ['edinburgh', 'scotland', 'uk']
          const locationPart = baseName
            .replace('pranay-m-travel-photography-', '')
            .split('-');
          
          // Extract the sequential index number (e.g., '01')
          const indexPart = locationPart.pop();
          
          // Join remaining words and capitalize for beautiful title casing
          const locationName = locationPart
            .map(word => word.charAt(0).toUpperCase() + word.slice(1))
            .join(' ');

          // Generate dynamic, premium alt descriptions
          let altText = '';
          const isPortrait = locationName.toLowerCase() === 'travel photo';
          if (isPortrait) {
            altText = `Travel photography portrait (#${indexPart}) by Pranay`;
          } else {
            altText = `Travel photography in ${locationName} (#${indexPart}) by Pranay`;
          }

          const captionText = isPortrait ? 'Portrait' : locationName;

          return (
            <div class="photo-card">
              <img src={imagePath} alt={altText} loading="lazy" />
              <div class="photo-caption">{captionText}</div>
            </div>
          );
        })}
      </div>
    </section>
  )}

  <!-- Blog & Writing Archives Section -->
  <section class="archive-section" id="blog">
    <h2>Writing Archive</h2>
    <ul class="post-list">
      {sortedPosts.slice(0, 7).map((post) => {
        // Format the date to YYYY-MM-DD for a clean, monospace look
        const dateObj = new Date(post.data.pubDate);
        const formattedDate = dateObj.toISOString().split('T')[0];
        
        return (
          <li class="post-item">
            <span class="post-meta-date">{formattedDate}</span>
            <a href={`/blog/${post.id}`} class="post-title-link">
              {post.data.title}
            </a>
          </li>
        );
      })}
    </ul>
    {sortedPosts.length > 7 && (
      <div style="margin-top: 2rem;">
        <a href="/blog" class="view-all-link">View all articles &rarr;</a>
      </div>
    )}
  </section>

  <!-- Client-side Shuffling and Auto-scrolling Script -->
  <script>
    // 1. Force the browser to disable automatic scroll position restoration on refresh
    if ('scrollRestoration' in history) {
      history.scrollRestoration = 'manual';
    }

    document.addEventListener('DOMContentLoaded', () => {
      const reel = document.querySelector('.photo-reel') as HTMLElement;
      if (!reel) return;

      // Disable layout behaviors that trigger browser scroll anchoring/snapping adjustments during shuffling
      reel.style.scrollBehavior = 'auto';
      reel.style.scrollSnapType = 'none';

      // Shuffle the cards in memory to avoid multiple layout passes
      const cards = Array.from(reel.children);
      for (let i = cards.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        const temp = cards[i];
        cards[i] = cards[j];
        cards[j] = temp;
      }

      // Re-append cards to the DOM in a single atomic operation
      reel.innerHTML = '';
      const fragment = document.createDocumentFragment();
      cards.forEach(card => fragment.appendChild(card));
      reel.appendChild(fragment);

      // Force scroll position instantly back to 0
      reel.scrollLeft = 0;

      // Use nested animation frames to allow the browser's layout engine to settle 
      // before re-enabling scroll snap and smooth transitions.
      requestAnimationFrame(() => {
        reel.scrollLeft = 0;
        requestAnimationFrame(() => {
          reel.style.scrollBehavior = 'smooth';
          reel.style.scrollSnapType = 'x mandatory';
        });
      });

      // 2. Auto-scrolling logic
      let scrollTimer: any = null;
      let startTimeout: any = null;
      let isPaused = false;

      function startAutoScroll(initialDelay = 2000, recurringDelay = 2000) {
        if (isPaused) return;
        
        // Use a setTimeout for the first transition delay
        startTimeout = setTimeout(() => {
          slideNext();
          // Set up recurring interval for subsequent slides
          scrollTimer = setInterval(slideNext, recurringDelay);
        }, initialDelay);
      }

      function slideNext() {
        const firstCard = reel.querySelector('.photo-card') as HTMLElement;
        if (!firstCard) return;

        const cardWidth = firstCard.offsetWidth;
        const gap = parseFloat(getComputedStyle(reel).gap) || 0;
        const step = cardWidth + gap;

        const maxScroll = reel.scrollWidth - reel.clientWidth - 10;
        
        if (reel.scrollLeft >= maxScroll) {
          // Loop back smoothly to the beginning
          reel.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          // Scroll to the next photo card
          reel.scrollTo({ left: reel.scrollLeft + step, behavior: 'smooth' });
        }
      }

      function stopAutoScroll() {
        clearTimeout(startTimeout);
        clearInterval(scrollTimer);
      }

      // Start auto-scroll: 3s initial load delay (2s slide + 1s extra), followed by a 2s recurring loop
      startAutoScroll(3000, 2000);

      // Pause interaction listeners
      reel.addEventListener('mouseenter', () => {
        isPaused = true;
        stopAutoScroll();
      }, { passive: true });

      reel.addEventListener('mouseleave', () => {
        isPaused = false;
        // Resume scrolling after the standard 2s interval
        startAutoScroll(2000, 2000);
      }, { passive: true });

      reel.addEventListener('pointerdown', () => {
        isPaused = true;
        stopAutoScroll();
      }, { passive: true });
    });
  </script>
</BaseLayout>
